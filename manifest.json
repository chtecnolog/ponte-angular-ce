{
  "manifest_version": 3,
  "name": "Angular Bridge Base",
  "version": "1.0",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["script_angular.js"],
      "world": "MAIN"
    }
  ]
}