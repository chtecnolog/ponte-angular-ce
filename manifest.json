{
  "manifest_version": 3,
  "name": "ponte-angular-ce",
  "version": "1.0",
  "permissions": ["activeTab", "scripting"],
  "description": "library for creating a bridge between chrome extensions and angular app",
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "mensageiro.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["manipulador.js"],
      "world": "MAIN"
    }
  ]
}